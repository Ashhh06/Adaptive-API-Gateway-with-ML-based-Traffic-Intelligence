# copy to .env and fill in values

PORT=3000
NODE_ENV=development

BACKEND_URL=http://127.0.0.1:5000
REDIS_URL=redis://127.0.0.1:6379
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.example.net/gateway

ML_SERVICE_URL=http://127.0.0.1:8000/predict
ML_TIMEOUT_MS=2000
ML_MAX_RETRIES=1
ML_CACHE_TTL=20
# ML_DEBUG=1

RATE_LIMIT_WINDOW=60
RLIMIT_NORMAL=100
RLIMIT_SUSPICIOUS=40
RLIMIT_MALICIOUS=0
RL_POLICY_TTL=120

# optional: gateway/scripts/trafficSimulator.js
# SIMULATION_BASE_URL=http://127.0.0.1:3000/api
